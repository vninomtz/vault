meta {
  name: Create Subscription (Webhook)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/subscriptions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "filter": { "type": "rule" },
    "channel": "webhook",
    "url": "https://ci.example.com/hooks/vault",
    "secret": "super-secret-hmac-key"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("subscriptionId", res.body.id);
  }
}
