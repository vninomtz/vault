meta {
  name: Create Token
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/tokens
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "name": "opencode-agent",
    "read": ["rule:*", "note:*"],
    "write": [],
    "expires_at": "2027-01-01T00:00:00.000Z"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("token", res.body.token);
  }
}
