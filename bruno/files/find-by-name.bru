meta {
  name: Find File (by name)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/files
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

params:query {
  name: projects/vault/typescript-rules
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("fileId", res.body.file.id);
  }
}
