meta {
  name: Write File
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/files/{{slug}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "content": "# TypeScript Rules\n\n- No usar `any`.\n- Siempre tipar los retornos de funciones.\n- Preferir `interface` sobre `type` para objetos.",
    "type": "rule"
  }
}
