meta {
  name: Write File (Binary Reference)
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/files/architecture-diagram
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "content_ref": "r2://vault-storage/diagrams/arch.pdf",
    "content_type": "application/pdf",
    "type": "note"
  }
}
