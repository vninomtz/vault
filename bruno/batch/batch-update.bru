meta {
  name: Batch Update
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/batch
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "atomic": false,
    "operations": [
      {
        "id": "{{fileId}}",
        "content": "# TypeScript Rules\n\nActualizado via batch."
      }
    ]
  }
}
