meta {
  name: File Conflicts
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/files/{{slug}}/conflicts
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

script:post-response {
  if (res.status === 200 && res.body.conflicts.length > 0) {
    bru.setVar("conflictId", res.body.conflicts[0].id);
  }
}
