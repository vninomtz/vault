meta {
  name: Resolve Conflict
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/files/{{fileId}}/conflicts/{{conflictId}}/resolve
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Vault-Version: 2026-05-26
}

body:json {
  {
    "content": "# TypeScript Rules (Reconciliado)\n\nEl proceso debe ser asíncrono por requisitos de latencia.\n\n- No usar `any`.\n- Usar `async/await` en lugar de callbacks.",
    "supersedes": []
  }
}
